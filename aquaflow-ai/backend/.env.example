# AquaFlow AI — Backend Environment Variables
# Copy this file to .env and fill in your values

APP_NAME=AquaFlow AI
DEBUG=false

# SQLite (default) — change to PostgreSQL for production
DATABASE_URL=sqlite+aiosqlite:///./aquaflow.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/aquaflow

# JWT Auth
SECRET_KEY=replace-this-with-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Anomaly detection thresholds
PRESSURE_MIN_BAR=1.5
PRESSURE_MAX_BAR=8.0
FLOW_RATE_MIN=0.0
FLOW_RATE_MAX=500.0
ANOMALY_ZSCORE_THRESHOLD=3.0
